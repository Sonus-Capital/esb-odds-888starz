{
    "title": "888starz esports odds input",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "hubSlugs": {
            "title": "Game hub slugs to scrape",
            "type": "array",
            "description": "Leave empty to scrape all supported esports.",
            "editor": "json",
            "default": [],
            "items": {
                "type": "string"
            }
        },
        "maxHubs": {
            "title": "Max number of hubs to scrape",
            "type": "integer",
            "description": "0 = unlimited.",
            "default": 0
        },
        "includeLine": {
            "title": "Include pre-match line",
            "description": "If true, fetch pre-match events.",
            "type": "boolean",
            "default": true
        },
        "includeLive": {
            "title": "Include live",
            "description": "If true, fetch live events.",
            "type": "boolean",
            "default": true
        },
        "proxyUrl": {
            "title": "Optional proxy URL",
            "type": "string",
            "editor": "textfield",
            "description": "HTTP/HTTPS proxy URL to route requests through.",
            "default": "",
            "nullable": true
        },
        "requestTimeout": {
            "title": "HTTP request timeout (seconds)",
            "type": "number",
            "description": "Per-request timeout.",
            "default": 30.0
        },
        "headless": {
            "title": "Run Playwright headless",
            "type": "boolean",
            "description": "If false, runs headed Chromium (useful for debugging).",
            "default": true
        }
    },
    "required": []
}
